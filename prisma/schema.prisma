generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id           String    @id @default(cuid())
  status       String
  /// `identifier_from_purchaser` from start_job (hash preimage)
  buyerId      String
  inputData    Json
  inputHash    String?
  outputData   Json?
  outputHash   String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  completedAt  DateTime?
}
